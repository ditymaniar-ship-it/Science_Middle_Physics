<script type="application/ld+json">
    {"@type":"Article","headline":"Atmospheric pressure | Definition, Measurement, & Variations","image":{"url":"https://cdn.britannica.com/03/5503-050-184F70BE/surface-pressure-altitude-Earth-Examination-data-relationship.jpg","@type":"ImageObject"},"keywords":"atmospheric pressure","wordcount":296,"url":"https://www.britannica.com/science/atmospheric-pressure","datePublished":"1998-07-20T00:00:00Z","dateModified":"2026-02-27T00:00:00Z","description":"Atmospheric pressure is the force per unit area exerted by a body of air above a specified area (called an atmospheric column). It is expressed in several different systems of units, including millimeters (or inches) of mercury, pounds per square inch (psi), millibars (mb), or standard atmospheres.","@context":"https://schema.org","author":[{"name":"Britannica Editors","url":"https://www.britannica.com/editor/The-Editors-of-Encyclopaedia-Britannica/4419","@type":"Person"}],"publisher":{"@type":"Organization","logo":{"url":"https://corporate.britannica.com/wp-content/themes/eb-corporate/_img/logo.png","@type":"ImageObject"},"name":"Encyclopedia Britannica"},"sameAs":"https://www.wikidata.org/wiki/Q81809"}
